FLASK_ENV=development
SECRET_KEY=dev-secret
JWT_SECRET_KEY=dev-jwt-secret-please-change-this-to-32-bytes-min
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_ALL=1
DATABASE_URL=sqlite:///farmlogistics.db
UPLOAD_DIR=uploads

# Bootstrap admin (dev only): create an admin user on startup if none exists.
BOOTSTRAP_ADMIN=0
ADMIN_FULL_NAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PHONE=07000000000
ADMIN_PASSWORD=admin@example.com

# JWT
JWT_EXPIRES_HOURS=24

# Shwary Mobile Money
SHWARY_MERCHANT_ID=your-merchant-id
SHWARY_MERCHANT_KEY=your-merchant-key
SHWARY_CALLBACK_URL=https://your-public-url.com/api/payments/callback
SHWARY_SANDBOX=1

# Twilio SMS (Optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
